{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "noEmit": false,
    "outDir": "./.typecheck",
    "rootDir": "./src",
    "tsBuildInfoFile": "./.typecheck/tsconfig.tsbuildinfo"
  },
  "include": ["src"]
}
