{
  "name": "@lcl/server",
  "private": true,
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@hono/zod-validator": "^0.7.6",
    "@langchain/core": "^1.1.36",
    "@langchain/google": "^0.1.8",
    "@lcl/types": "workspace:*",
    "@lcl/utils": "workspace:*",
    "drizzle-orm": "^0.42.0",
    "hono": "^4.6.10",
    "langchain": "^1.2.37",
    "postgres": "^3.4.5",
    "zod": "^4.3.6"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "debug": "bun --inspect-wait=localhost:6499/lcl-server --hot src/index.ts",
    "build": "tsc -b --pretty false && bun build ./src/index.ts --target=bun --outfile=./dist/index.js",
    "typecheck": "tsc -b --pretty false",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "type": "module",
  "devDependencies": {
    "drizzle-kit": "^0.31.1"
  }
}
