{
  "name": "@lcl/client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b --pretty false && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
