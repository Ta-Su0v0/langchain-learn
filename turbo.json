{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": [
        "bun.lock",
        "package.json",
        "tsconfig.json",
        "tsconfig.base.json"
    ],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", "build/**"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "test": {
            "dependsOn": ["^test"]
        },
        "typecheck": {
            "dependsOn": ["^typecheck"],
            "cache": true
        }
    }
}
